	"
# Provides the virtual `wpewebkit` and the WPE sonames kumo links against.
provides="wpewebkit=$pkgver-r$pkgrel"
subpackages="$pkgname-dev"
options="!check" # WPE port ships no runnable test suite in release tarballs
source="wpewebkit-$pkgver.tar.zst::https://github.com/jishin-v/jishin-alpine-repository-bulk/raw/refs/heads/master/wpewebkit-kumo/wpewebkit-$pkgver.tar.zst"
builddir="$srcdir/wpewebkit-$pkgver"

build() {
	# Upstream prefers Clang; matches Alpine's webkit2gtk aport and roughly
	# halves the size of the debug symbols.
	export CC=clang
	export CXX=clang++
	export AR=llvm-ar
	export NM=llvm-nm
	export RANLIB=llvm-ranlib
	export LDFLAGS="$LDFLAGS -fuse-ld=lld"

	# WebKit is broken with _FORTIFY_SOURCE; keep debug symbols small.
	export CFLAGS="$CFLAGS -U_FORTIFY_SOURCE -g1"
	export CXXFLAGS="$CXXFLAGS -U_FORTIFY_SOURCE -g1"

	# JIT-ted code crashes with CET enabled on x86_64.
	case "$CARCH" in
		x86_64)
			export CFLAGS="$CFLAGS -fcf-protection=none"
			export CXXFLAGS="$CXXFLAGS -fcf-protection=none"
			;;
	esac

	cmake -B build -G Ninja \
		-DPORT=WPE \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_SKIP_RPATH=ON \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DCMAKE_INSTALL_LIBEXECDIR=lib \
		-DENABLE_DOCUMENTATION=OFF \
		-DENABLE_JOURNALD_LOG=OFF \
		-DENABLE_MINIBROWSER=OFF \
		-DENABLE_SAMPLING_PROFILER=OFF \
		-DENABLE_SPEECH_SYNTHESIS=OFF \
		-DENABLE_WPE_PLATFORM=ON \
		-DUSE_LIBBACKTRACE=OFF
	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build
}

