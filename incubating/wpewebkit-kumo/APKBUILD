	libwebp
	libxkbcommon
	libxml2
	libxslt
	libsoup3
	mesa
	openjpeg
	sqlite-libs
	wayland-libs-client
	woff2
	xdg-dbus-proxy
	"
makedepends="
	at-spi2-core-dev
	bison
	clang
	cmake
	flex
	gobject-introspection-dev
	gperf
	gst-plugins-bad-dev
	gst-plugins-base-dev
	gstreamer-dev
	hyphen-dev
	icu-dev
	lcms2-dev
	libavif-dev
	libdrm-dev
	libepoxy-dev
	libgcrypt-dev
	libinput-dev
