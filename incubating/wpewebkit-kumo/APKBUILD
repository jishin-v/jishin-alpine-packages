# WPE WebKit fork used by the `kumo` browser. Packaged from the
# chrisduerr/WebKit fork (tag v2.52.4) since GitHub refuses to generate
# archives for it (HTTP 422); the source tarball is mirrored via Git LFS in
# the sibling jishin-alpine-repository-bulk repo (built by
# prepare-source.sh, which prunes build-irrelevant subtrees like
# LayoutTests/JSTests/Websites).
#
# The build recipe mirrors Alpine's own community/webkit2gtk-4.1 aport
# (clang+lld, samurai, -U_FORTIFY_SOURCE -g1), adapted to the WPE port and
# the -DENABLE_WPE_PLATFORM=ON flag that kumo's wpe-platform bindings need.
pkgname=wpewebkit-kumo
pkgver=2.52.4
pkgrel=0
pkgdesc="Embeddable web content engine (WPE port, kumo fork)"
url="https://github.com/chrisduerr/WebKit"
arch="aarch64 x86_64"
license="
	AFL-2.0 OR GPL-2.0-or-later
	Apache-2.0
