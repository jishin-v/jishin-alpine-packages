	BSD-Source-Code
	BSL-1.0
	bzip2-1.0.6
	GPL-2.0-only
	GPL-3.0-only WITH Autoconf-exception-3.0
	GPL-3.0-or-later WITH Bison-exception-2.2
	ICU
	ISC
	LGPL-2.1-only
	LGPL-2.1-or-later
	MIT
	MPL-1.1
	MPL-2.0
	NCSA
	NCSA OR MIT
	OFL-1.1
	SunPro
	Unicode-TOU
	"
# Runtime libs the engine links; the rest (cairo/pango/glib/...) are pulled
# transitively by apk and/or abuild's automatic so: dependency tracing.
depends="
	!wpewebkit
	at-spi2-core
	bubblewrap
	gst-plugins-bad
